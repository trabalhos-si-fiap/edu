COMPOSE_PROJECT_NAME=edu

ENV=development
DEBUG=true

POSTGRES_USER=edu
POSTGRES_PASSWORD=edu
POSTGRES_DB=edu
DATABASE_URL=postgresql+asyncpg://edu:edu@postgres:5432/edu
DATABASE_URL_TEST=postgresql+asyncpg://edu:edu@postgres:5432/edu_test

REDIS_PASSWORD=edu
REDIS_URL=redis://:edu@redis:6379/0
REDIS_URL_TEST=redis://:edu@redis:6379/15

RABBITMQ_USER=edu
RABBITMQ_PASSWORD=edu
CELERY_BROKER_URL=amqp://edu:edu@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:edu@redis:6379/1

SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
BCRYPT_ROUNDS=12

LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
